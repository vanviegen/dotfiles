# Should work in both bash and zsh (as the rc files are symlinked)
case $- in *i*)
    if [ -z "$IN_FISH" ] && [ -z "$ANTIGRAVITY_AGENT" ] && [ -z "$VSCODE_GIT_IPC_HANDLE" ]; then
        export IN_FISH=true
        FISH="$(which fish)"
        if [ "$FISH" = "" ]; then
            echo "fish cannot be found in path: $PATH"
        else
            SHELL="$FISH" exec "$FISH"
        fi
    fi
esac
export PATH="$HOME/.linuxbrew/bin:/home/linuxbrew/.linuxbrew/bin:$PATH"
