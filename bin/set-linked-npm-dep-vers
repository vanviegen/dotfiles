#!/usr/bin/env node

const fs = require('fs');
const path = require('path');

const pkgPath = path.resolve('package.json');
if (!fs.existsSync(pkgPath)) {
  console.error('No package.json found in current directory.');
  process.exit(1);
}

const pkg = JSON.parse(fs.readFileSync(pkgPath, 'utf8'));
const nodeModules = path.resolve('node_modules');

const depFields = [
  'dependencies',
  'devDependencies',
  'peerDependencies',
  'optionalDependencies',
];

let updatedCount = 0;

for (const field of depFields) {
  const deps = pkg[field];
  if (!deps) continue;

  for (const name of Object.keys(deps)) {
    const depDir = path.join(nodeModules, name);

    let stat;
    try {
      stat = fs.lstatSync(depDir);
    } catch {
      continue;
    }

    if (!stat.isSymbolicLink()) continue;

    // It's a symlink (linked dependency)
    const linkedPkgPath = path.join(depDir, 'package.json');
    let linkedPkg;
    try {
      linkedPkg = JSON.parse(fs.readFileSync(linkedPkgPath, 'utf8'));
    } catch {
      console.warn(`  ⚠ Could not read package.json for linked dep: ${name}`);
      continue;
    }

    const version = linkedPkg.version;
    if (!version) {
      console.warn(`  ⚠ No version field in linked dep: ${name}`);
      continue;
    }

    const newRange = `^${version}`;
    if (deps[name] !== newRange) {
      console.log(`  ${field}: ${name} "${deps[name]}" → "${newRange}"`);
      deps[name] = newRange;
      updatedCount++;
    }
  }
}

if (updatedCount === 0) {
  console.log('No linked dependencies found or nothing to update.');
} else {
  fs.writeFileSync(pkgPath, JSON.stringify(pkg, null, 2) + '\n', 'utf8');
  console.log(`\nUpdated ${updatedCount} version(s) in package.json.`);
}
